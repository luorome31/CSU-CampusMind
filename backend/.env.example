# CampusMind Backend Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Storage Configuration
# ===========================================
# Choose: minio or oss
STORAGE_MODE=minio

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=campusmind

# OR Aliyun OSS Configuration
# STORAGE_MODE=oss
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your_access_key
# OSS_ACCESS_KEY_SECRET=your_secret_key
# OSS_BUCKET=campusmind

# ===========================================
# Embedding Configuration
# ===========================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-api-key

# Or use other providers:
# EMBEDDING_BASE_URL=https://api.deepseek.com/v1
# EMBEDDING_API_KEY=sk-xxx

# ===========================================
# Elasticsearch Configuration
# ===========================================
ELASTICSEARCH_HOSTS=http://localhost:9200

# ===========================================
# ChromaDB Configuration
# ===========================================
CHROMA_PERSIST_PATH=./data/chroma

# ===========================================
# Database Configuration
# ===========================================
# SQLite for testing (default)
# DATABASE_URL=sqlite:///./campusmind.db

# PostgreSQL for production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campusmind
